# Azure OpenAI (GPT Vision)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5
AZURE_OPENAI_DEPLOYMENT_FAST=gpt-5-nano
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# OpenAI Direct API (vision fallback and web search)
OPENAI_DIRECT_API_KEY=

# Google Cloud Vision — path to service account JSON (or leave unset if using Mimir_key.json in this directory)
GOOGLE_APPLICATION_CREDENTIALS=

# Google Custom Search (GPT Vision + Search)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Google Maps (GPS enrichment)
GOOGLE_MAPS_API_KEY=

# Google Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-3-flash-preview
GEMINI_MODEL_STRONG=gemini-3-pro-preview
